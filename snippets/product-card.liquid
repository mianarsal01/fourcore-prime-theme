{%- liquid
  assign card_product = product
  assign featured_media = card_product.featured_media
  assign card_variant = card_product.selected_or_first_available_variant
-%}

<article class="card" aria-label="{{ card_product.title | escape }}">
  <a href="{{ card_product.url }}" class="card__media" aria-label="{{ card_product.title | escape }}">
    {%- if featured_media -%}
      {{
        featured_media
        | image_url: width: 720
        | image_tag:
          widths: '240,360,480,720',
          loading: 'lazy',
          sizes: '(min-width: 990px) 25vw, 50vw',
          alt: card_product.title
      }}
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag }}
    {%- endif -%}

    {%- if card_variant.compare_at_price > card_variant.price -%}
      <span class="card__badge">Sale</span>
    {%- endif -%}
  </a>

  <div class="card__content">
    <a href="{{ card_product.url }}" class="card__title">{{ card_product.title }}</a>
    {%- render 'price', target: card_product -%}

    <div class="card__actions">
      {%- if card_product.available and card_product.variants.size == 1 -%}
        {%- form 'product', card_product, class: 'card__quick-add', data-product-form: '' -%}
          <input type="hidden" name="id" value="{{ card_variant.id }}">
          <input type="hidden" name="quantity" value="1">
          <button type="submit" data-add-to-cart>Add</button>
        {%- endform -%}
      {%- else -%}
        <a class="button button--secondary" href="{{ card_product.url }}">Choose options</a>
      {%- endif -%}

      <button
        type="button"
        class="button button--secondary card__quick-view"
        data-quick-view-open
        data-product-handle="{{ card_product.handle }}"
      >
        Quick view
      </button>
    </div>
  </div>
</article>
