  <div class="quick-view-modal__panel" role="dialog" aria-modal="true" aria-label="Quick view product">
    <div class="quick-view-modal__head">
      <h2>Quick view</h2>
      <button type="button" class="quick-view-modal__close" data-quick-view-close aria-label="Close quick view">&times;</button>
    </div>
    <div class="quick-view-modal__body" data-quick-view-content>
      <p>Loading...</p>
    </div>
  </div>
</div>
