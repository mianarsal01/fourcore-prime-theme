<section class="page-width" style="padding: 2rem 0;">
  <h2>{{ section.settings.heading }}</h2>

  <div class="grid product-grid">
    {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
      {%- render 'product-card', product: product -%}
    {%- else -%}
      {%- for index in (1..section.settings.products_to_show) -%}
        <article class="card">
          <div class="card__media">{{ 'product-1' | placeholder_svg_tag }}</div>
          <p>Sample product {{ index }}</p>
        </article>
      {%- endfor -%}
    {%- endfor -%}
  </div>

  {%- if section.settings.collection != blank -%}
    <p><a href="{{ section.settings.collection.url }}">{{ 'general.view_all' | t }}</a></p>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Featured products"
    }
  ]
}
{% endschema %}
