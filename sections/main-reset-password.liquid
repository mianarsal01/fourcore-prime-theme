<section class="page-width" style="padding: 2rem 0; max-width: 36rem;">
  <h1>Reset password</h1>

  {%- form 'reset_customer_password' -%}
    <label for="ResetPassword">New password</label>
    <input id="ResetPassword" type="password" name="customer[password]" autocomplete="new-password" required>

    <label for="PasswordConfirmation">Confirm password</label>
    <input id="PasswordConfirmation" type="password" name="customer[password_confirmation]" autocomplete="new-password" required>

    <button type="submit">Reset</button>
  {%- endform -%}
</section>

{% schema %}
{
  "name": "Main reset password",
  "settings": []
}
{% endschema %}
