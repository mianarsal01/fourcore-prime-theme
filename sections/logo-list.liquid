<section class="page-width section-pad logo-list">
  {%- if section.settings.heading != blank -%}
    <h2>{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="logo-list__grid">
    {%- for block in section.blocks -%}
      <div class="logo-list__item" {{ block.shopify_attributes }}>
        {%- if block.settings.logo != blank -%}
          {{
            block.settings.logo
            | image_url: width: 320
            | image_tag: widths: '120,180,240,320', loading: 'lazy', alt: block.settings.alt
          }}
        {%- else -%}
          <span>{{ block.settings.alt }}</span>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Logo list",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured in"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Logo name",
          "default": "Brand"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Logo list",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
