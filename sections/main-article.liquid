{%- render 'breadcrumbs' -%}

<article class="page-width" style="padding: 2rem 0;">
  <h1>{{ article.title }}</h1>
  {%- if article.image -%}
    {{ article.image | image_url: width: 1400 | image_tag: widths: '480,720,960,1400', loading: 'lazy' }}
  {%- endif -%}
  <div>{{ article.content }}</div>
</article>

{% schema %}
{
  "name": "Main article",
  "settings": []
}
{% endschema %}
