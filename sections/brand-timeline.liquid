<section class="page-width section-pad brand-timeline">
  {%- if section.settings.heading != blank -%}
    <h2>{{ section.settings.heading }}</h2>
  {%- endif -%}

  <ol class="brand-timeline__list">
    {%- for block in section.blocks -%}
      <li {{ block.shopify_attributes }}>
        <p class="brand-timeline__year">{{ block.settings.year }}</p>
        <h3>{{ block.settings.heading }}</h3>
        <p>{{ block.settings.text }}</p>
      </li>
    {%- endfor -%}
  </ol>
</section>

{% schema %}
{
  "name": "Brand timeline",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our story"
    }
  ],
  "blocks": [
    {
      "type": "milestone",
      "name": "Milestone",
      "settings": [
        { "type": "text", "id": "year", "label": "Year", "default": "2026" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Milestone" },
        { "type": "text", "id": "text", "label": "Text", "default": "Describe an important brand moment." }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Brand timeline",
      "blocks": [
        { "type": "milestone" },
        { "type": "milestone" },
        { "type": "milestone" }
      ]
    }
  ]
}
{% endschema %}
