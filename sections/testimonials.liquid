<section class="page-width section-pad testimonials">
  {%- if section.settings.heading != blank -%}
    <h2>{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="testimonials__grid">
    {%- for block in section.blocks -%}
      <blockquote class="testimonial" {{ block.shopify_attributes }}>
        <p>"{{ block.settings.quote }}"</p>
        <cite>{{ block.settings.author }}</cite>
      </blockquote>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Loved by customers"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "Great quality and super fast shipping."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Customer name"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
