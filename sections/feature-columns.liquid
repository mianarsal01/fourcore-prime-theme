<section class="page-width section-pad feature-columns">
  {%- if section.settings.heading != blank -%}
    <h2>{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="feature-columns__grid">
    {%- for block in section.blocks -%}
      <article class="feature-column" {{ block.shopify_attributes }}>
        <h3>{{ block.settings.heading }}</h3>
        <p>{{ block.settings.text }}</p>
      </article>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Feature columns",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why customers choose us"
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Fast delivery" },
        { "type": "text", "id": "text", "label": "Text", "default": "Get your order quickly with reliable shipping." }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Feature columns",
      "blocks": [
        { "type": "column" },
        { "type": "column" },
        { "type": "column" }
      ]
    }
  ]
}
{% endschema %}
