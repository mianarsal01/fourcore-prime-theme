<section class="page-width section-pad faq">
  {%- if section.settings.heading != blank -%}
    <h2>{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="faq__items">
    {%- for block in section.blocks -%}
      <details {{ block.shopify_attributes }}>
        <summary>{{ block.settings.question }}</summary>
        <div>{{ block.settings.answer }}</div>
      </details>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently asked questions"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How long does shipping take?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Orders ship in 1-2 business days.</p>"
        }
      ]
    }
  ],
  "max_blocks": 16,
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "item" },
        { "type": "item" },
        { "type": "item" }
      ]
    }
  ]
}
{% endschema %}
