<section class="page-width section-pad collection-showcase">
  {%- if section.settings.heading != blank -%}
    <h2>{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="collection-showcase__grid">
    {%- for block in section.blocks -%}
      {%- if block.settings.collection != blank -%}
        <article class="collection-showcase__card" {{ block.shopify_attributes }}>
          <a href="{{ block.settings.collection.url }}">
            {%- if block.settings.collection.featured_image != blank -%}
              {{
                block.settings.collection.featured_image
                | image_url: width: 900
                | image_tag:
                  widths: '320,480,640,900',
                  loading: 'lazy',
                  alt: block.settings.collection.title
              }}
            {%- endif -%}
            <h3>{{ block.settings.collection.title }}</h3>
            <p>{{ block.settings.collection.products_count }} products</p>
          </a>
        </article>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection showcase",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Browse collections" }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Collection showcase",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
