<section class="page-width section-pad before-after">
  {%- if section.settings.heading != blank -%}
    <h2>{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="before-after__frame" data-before-after>
    <div class="before-after__image before-after__image--after">
      {%- if section.settings.after_image != blank -%}
        {{ section.settings.after_image | image_url: width: 1800 | image_tag: widths: '480,720,960,1280,1800', loading: 'lazy', alt: 'After' }}
      {%- endif -%}
    </div>
    <div class="before-after__image before-after__image--before" data-before-after-overlay>
      {%- if section.settings.before_image != blank -%}
        {{ section.settings.before_image | image_url: width: 1800 | image_tag: widths: '480,720,960,1280,1800', loading: 'lazy', alt: 'Before' }}
      {%- endif -%}
    </div>
    <input type="range" min="0" max="100" value="50" data-before-after-range aria-label="Before after slider">
  </div>
</section>

{% schema %}
{
  "name": "Before/after slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See the difference"
    },
    {
      "type": "image_picker",
      "id": "before_image",
      "label": "Before image"
    },
    {
      "type": "image_picker",
      "id": "after_image",
      "label": "After image"
    }
  ],
  "presets": [
    {
      "name": "Before/after slider"
    }
  ]
}
{% endschema %}
