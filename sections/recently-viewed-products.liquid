{%- if section.settings.heading != blank -%}
  <section class="page-width recently-viewed" style="padding: 2rem 0;" data-recently-viewed data-limit="{{ section.settings.products_to_show }}">
    <h2>{{ section.settings.heading }}</h2>
    <div class="grid product-grid" data-recently-viewed-grid>
      <p data-recently-viewed-empty>Recently viewed products appear for returning shoppers.</p>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Recently viewed",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Recently viewed"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Recently viewed"
    }
  ]
}
{% endschema %}
