<section class="page-width section-pad comparison-table">
  {%- if section.settings.heading != blank -%}
    <h2>{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="comparison-table__wrap">
    <table>
      <thead>
        <tr>
          <th>Feature</th>
          <th>{{ section.settings.column_primary }}</th>
          <th>{{ section.settings.column_secondary }}</th>
        </tr>
      </thead>
      <tbody>
        {%- for block in section.blocks -%}
          <tr {{ block.shopify_attributes }}>
            <th>{{ block.settings.feature }}</th>
            <td>{{ block.settings.primary_value }}</td>
            <td>{{ block.settings.secondary_value }}</td>
          </tr>
        {%- endfor -%}
      </tbody>
    </table>
  </div>
</section>

{% schema %}
{
  "name": "Comparison table",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "How we compare" },
    { "type": "text", "id": "column_primary", "label": "Primary column", "default": "Our brand" },
    { "type": "text", "id": "column_secondary", "label": "Secondary column", "default": "Others" }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Row",
      "settings": [
        { "type": "text", "id": "feature", "label": "Feature", "default": "Shipping speed" },
        { "type": "text", "id": "primary_value", "label": "Primary value", "default": "2 days" },
        { "type": "text", "id": "secondary_value", "label": "Secondary value", "default": "5+ days" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Comparison table",
      "blocks": [
        { "type": "row" },
        { "type": "row" },
        { "type": "row" }
      ]
    }
  ]
}
{% endschema %}
