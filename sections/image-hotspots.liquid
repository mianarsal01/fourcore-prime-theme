<section class="page-width section-pad image-hotspots">
  {%- if section.settings.heading != blank -%}
    <h2>{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="image-hotspots__canvas">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2200 | image_tag: widths: '640,960,1280,1600,2200', loading: 'lazy' }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag }}
    {%- endif -%}

    {%- for block in section.blocks -%}
      <button
        type="button"
        class="hotspot"
        style="left: {{ block.settings.left }}%; top: {{ block.settings.top }}%;"
        data-hotspot-toggle
        aria-expanded="false"
        {{ block.shopify_attributes }}
      >
        <span class="visually-hidden">Open hotspot</span>
        +
      </button>
      <div
        class="hotspot-card"
        style="left: {{ block.settings.left }}%; top: {{ block.settings.top }}%;"
        data-hotspot-card
        hidden
      >
        <h3>{{ block.settings.heading }}</h3>
        <p>{{ block.settings.text }}</p>
        {%- if block.settings.link != blank and block.settings.button_label != blank -%}
          <a class="button button--secondary" href="{{ block.settings.link }}">{{ block.settings.button_label }}</a>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Image hotspots",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop the look" },
    { "type": "image_picker", "id": "image", "label": "Image" }
  ],
  "blocks": [
    {
      "type": "hotspot",
      "name": "Hotspot",
      "settings": [
        { "type": "range", "id": "left", "label": "Horizontal position", "min": 5, "max": 95, "step": 1, "default": 40, "unit": "%" },
        { "type": "range", "id": "top", "label": "Vertical position", "min": 5, "max": 95, "step": 1, "default": 40, "unit": "%" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Featured item" },
        { "type": "text", "id": "text", "label": "Text", "default": "Highlight product details or campaign copy." },
        { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop now" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Image hotspots",
      "blocks": [
        { "type": "hotspot" },
        { "type": "hotspot" }
      ]
    }
  ]
}
{% endschema %}
